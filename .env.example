# TITAN Wallet frontend environment
# Copy this file to `.env.local` for local development.

# Integrity API base URL.
VITE_TITAN_API_BASE_URL=https://api.yieldboostai.xyz

# Optional override for the military-grade execution base URL.
# Leave unset in production wallet deployments to use the same-origin wallet proxy.
VITE_TITAN_MILITARY_GRADE_BASE_URL=

# Developer portal / store URL surfaced in Settings.
VITE_TITAN_DEV_PORTAL_URL=https://dev.yieldboostai.xyz

# Optional default API key for local development only.
# Use a managed key from https://dev.yieldboostai.xyz/console for wallet testing.
VITE_TITAN_API_KEY=

# Optional Privy App ID for Google / Apple social login + embedded MPC wallet creation.
# Do not place your Privy App Secret in any Vite-prefixed variable.
VITE_PRIVY_APP_ID=

# Default environment for protected YieldBoost API requests.
# Allowed values: testnet | mainnet
VITE_TITAN_API_ENV=mainnet
